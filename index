        function waLink(text) { return `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(text)}`; }

        // ─── AGRUPACIÓN ───
        function groupByName(items) {
            const groups = [], byName = {};
            items.forEach(p => {
                if (!byName[p.name]) {
                    byName[p.name] = { name: p.name, slug: p.slug, brand: p.brand, condition: p.condition, variants: [], colors: [], storages: [], minPrice: Infinity, tags: new Set() };
                    groups.push(byName[p.name]);
                }
                const g = byName[p.name];
                g.variants.push(p);
                if (!g.colors.includes(p.color)) g.colors.push(p.color);
                if (!g.storages.includes(p.storage)) g.storages.push(p.storage);
                g.minPrice = Math.min(g.minPrice, p.price);
                if (p.tag) g.tags.add(p.tag);
            });
            return groups;
        }

        function groupCardHTML(g) {
            const tag = g.tags.has('OFERTA') ? 'OFERTA' : g.tags.has('NUEVO') ? 'NUEVO' : g.tags.has('SELLADO') ? 'SELLADO' : g.tags.has('DESTACADO') ? 'DESTACADO' : '';
            const tagHTML = tag ? `<span class="card-tag ${tagClassFor(tag)}">${tag === 'DESTACADO' ? 'TOP' : tag}</span>` : '';
            const condClass = g.condition || 'seminuevo';
            const condLabel = condClass === 'sellado' ? 'Sellado' : condClass === 'reacondicionado' ? 'Reacond.' : 'Seminuevo';
            const condHTML = `<span class="cond-badge ${condClass}">${condLabel}</span>`;
            const multi = g.variants.length > 1;
            const meta = multi ? `${g.colors.length} color${g.colors.length > 1 ? 'es' : ''} · ${g.storages.length} capacidad${g.storages.length > 1 ? 'es' : ''}` : `${g.storages[0]} · ${g.colors[0]}`;
            const priceLabel = multi ? `<span class="p-from">Desde</span><span class="p-price">${formatCLP(g.minPrice)}</span>` : `<span class="p-price">${formatCLP(g.minPrice)}</span>`;
            return `
                <article class="card" onclick="openDetail('${esc(g.name)}')">
                    ${tagHTML}${condHTML}
                    <div class="img-box" data-name="${g.name}"><img src="${imgFor(g.variants[0])}" alt="${g.name}" loading="lazy" onerror="this.closest('.img-box').classList.add('img-missing')"></div>
