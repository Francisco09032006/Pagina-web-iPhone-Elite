        // ─── DETAIL MODAL ───
        const detailState = { name: '', color: '', storage: '' };
        function openDetail(modelName) {
            const variants = stock.filter(p => p.name === modelName);
            if (!variants.length) return;
            detailState.name = modelName;
            const best = variants.find(v => v.tag === 'OFERTA') || variants.find(v => v.oldPrice) || variants[0];
