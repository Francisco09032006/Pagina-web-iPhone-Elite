        function renderStock() {
            const items = stock.filter(p => !p.isAccessory && (activeFilter === 'all' || deviceType(p.brand) === activeFilter));
            const groups = groupByName(items);
            const byCond = {
                sellado: groups.filter(g => g.condition === 'sellado'),
                seminuevo: groups.filter(g => g.condition === 'seminuevo'),
                reacondicionado: groups.filter(g => g.condition === 'reacondicionado')
            };
            const blocks = [
                { block: 'block-sellado', grid: 'grid-sellado', count: 'count-sellado', data: byCond.sellado },
                { block: 'block-seminuevo', grid: 'grid-seminuevo', count: 'count-seminuevo', data: byCond.seminuevo },
                { block: 'block-reac', grid: 'grid-reac', count: 'count-reac', data: byCond.reacondicionado }
