        function setWaLinks() {
            const greet = waLink('Hola iPhone Elite 👋 Vengo de su página web y quiero más información. ¿Me ayudan? 📱');
            ['hero-wa', 'foot-wa', 'foot-wa-link', 'fab-wa', 'sm-wa'].forEach(id => { const el = document.getElementById(id); if (el) el.href = greet; });
        }

        // ─── INTRO + INIT ───
        let entered = false;
        function enterSite() {
            if (entered) return; entered = true;
            const intro = document.getElementById('intro');
            intro.classList.add('gone');
            setTimeout(() => { intro.style.display = 'none'; }, 1000);
        }
        function init() {
            document.getElementById('hero-device-img').src = imgForSlug('iphone-17-pro');
            document.getElementById('year').textContent = '2026';
            setWaLinks();
            renderFilters(); renderStock(); renderBestsellers(); renderOffers(); renderAccessories();
            renderFAQ(); setupStarPicker(); renderReviews();
            initReveal(); initHeaderScroll(); initMagnetic(); startSocialProof();
            // auto-cierre del intro de respaldo
            setTimeout(() => { if (!entered) enterSite(); }, 4200);
        }

        document.addEventListener('keydown', e => {
            if (e.key !== 'Escape') return;
            const close = (id, fn) => { const el = document.getElementById(id); if (el && el.classList.contains('open')) { fn(); return true; } };
            if (close('lightbox', closeLightbox)) return;
            if (close('search', toggleSearch)) return;
            if (close('detail', closeDetail)) return;
            if (close('cart-panel', toggleCart)) return;
            if (close('side-menu', toggleSideMenu)) return;
        });

        window.addEventListener('DOMContentLoaded', init);
    </script>
</body>

</html>
